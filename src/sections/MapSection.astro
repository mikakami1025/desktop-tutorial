---
import { contactInfo } from '@/data/contact';

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(contactInfo.address)}&output=embed`;
---

<section class="map-section" aria-labelledby="map-title">
  <div class="container">
    <div class="map-section__heading">
      <p class="eyebrow">Google Map</p>
      <h2 id="map-title">Map</h2>
      <p>{contactInfo.address}</p>
    </div>
  </div>
  <iframe
    title="Miyuki日本水晶花藝 Google Map"
    src={mapSrc}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
</section>
