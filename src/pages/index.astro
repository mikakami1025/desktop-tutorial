---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import AboutSection from '@/sections/AboutSection.astro';
import ContactSection from '@/sections/ContactSection.astro';
import MapSection from '@/sections/MapSection.astro';
---

<BaseLayout
  title="Miyuki日本水晶花藝｜日系花藝生活品牌"
  description="Miyuki日本水晶花藝以日本水晶花、American Flower材料技法、工藝盆栽與認證教室資訊，呈現靜謐、透明感與生活感的花藝品牌網站。"
  image="assets/optimized/hero/miyuki-crystal-flower-gallery.jpg"
>
  <PageHero
    eyebrow="American Flower"
    title="Miyuki日本水晶花藝 | アメリカンフラワー"
    description="Miyuki日本水晶花藝以日本水晶花、American Flower材料技法、工藝盆栽與認證教室資訊，呈現靜謐、透明感與生活感的花藝品牌網站。"
  />
  <AboutSection />
  <ContactSection />
  <MapSection />
</BaseLayout>
